# ========================================
# AI API Keys
# ========================================

# GPT-4o (主力)
OPENAI_API_KEY=sk-xxx

# Claude 3.5 (仕上げ)
ANTHROPIC_API_KEY=sk-ant-xxx

# Qwen (オプション)
ALIBABA_CLOUD_API_KEY=xxx
QWEN_ENDPOINT=https://dashscope.aliyuncs.com

# GLM (オプション)
ZHIPU_API_KEY=xxx
GLM_ENDPOINT=https://open.bigmodel.cn/api

# DeepSeek (オプション)
DEEPSEEK_API_KEY=sk-xxx

# ========================================
# Database
# ========================================
DATABASE_URL=sqlite:///./gensou-ai.db

# PostgreSQL (本番用)
# DATABASE_URL=postgresql://gensou_ai:password@localhost:5432/gensou_ai

# ========================================
# App
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="GenSou (玄想)"

# ========================================
# Fine-tuning
# ========================================
# Hugging Face (モデル公開用)
HUGGING_FACE_TOKEN=hf_xxx

# GPU クラウド (オプション)
# RUNPOD_API_KEY=xxx
# LAMBDA_LABS_KEY=xxx

# ========================================
# Notifications
# ========================================
# Vercel Webhook Secret (プッシュ通知用)
VERCEL_WEBHOOK_SECRET=your-webhook-secret-here

# Vercel Project ID (オプション)
NEXT_PUBLIC_VERCEL_PROJECT_ID=your-project-id
